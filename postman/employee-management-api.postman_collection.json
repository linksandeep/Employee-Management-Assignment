{
  "info": {
    "name": "Employee Management API",
    "description": "Postman collection for the Employee Management CRUD REST API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "employeeId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Create Employee",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Aarav\",\n  \"lastName\": \"Sharma\",\n  \"email\": \"aarav.sharma@example.com\",\n  \"phone\": \"+91 9876543210\",\n  \"position\": \"Backend Developer\",\n  \"department\": \"Engineering\",\n  \"salary\": 75000,\n  \"status\": \"active\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employees",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employees"
          ]
        }
      }
    },
    {
      "name": "Get All Employees",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employees",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employees"
          ]
        }
      }
    },
    {
      "name": "Get Employee by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employees",
            "{{employeeId}}"
          ]
        }
      }
    },
    {
      "name": "Update Employee",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"position\": \"Senior Backend Developer\",\n  \"salary\": 90000,\n  \"status\": \"active\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employees",
            "{{employeeId}}"
          ]
        }
      }
    },
    {
      "name": "Delete Employee",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employees",
            "{{employeeId}}"
          ]
        }
      }
    }
  ]
}
